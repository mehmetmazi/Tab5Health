#pragma once
// Copy this file to withings_credentials.h (which is gitignored).
// 1. Register an app at https://developer.withings.com
//    with callback URL  http://localhost:8080/callback
// 2. Do the one-time browser authorization on your computer to obtain an
//    initial refresh token (see the "Credentials" section of the README).
// The device refreshes + rotates this token from then on (persisted to NVS).
#define WITHINGS_CLIENT_ID     "your-withings-client-id"
#define WITHINGS_CLIENT_SECRET "your-withings-client-secret"
#define WITHINGS_REFRESH_TOKEN "your-initial-refresh-token"
